<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- An executable the multi-process specifications spawn, not a test assembly - the test runner must not try to execute it. -->
    <IsTestProject>false</IsTestProject>
  </PropertyGroup>
  <!-- Compze.DependencyInjection.Microsoft — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_DependencyInjection_Microsoft)' == 'true'">
    <PackageReference Include="Compze.DependencyInjection.Microsoft" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_DependencyInjection_Microsoft)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.DependencyInjection.Microsoft\Compze.DependencyInjection.Microsoft.csproj" />
  </ItemGroup>
  <!-- Compze.Hosting — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Hosting)' == 'true'">
