<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.0.0" />
    <PackageReference Include="Serilog" Version="4.3.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="xunit.v3" Version="3.1.0" />
  </ItemGroup>
  <!-- Compze.Internals.Logging — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Logging)' == 'true'">
    <PackageReference Include="Compze.Internals.Logging" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Logging)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Internals.Logging\Compze.Internals.Logging.csproj" />
  </ItemGroup>
  <!-- Compze.Internals.Logging.Serilog — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Logging_Serilog)' == 'true'">
    <PackageReference Include="Compze.Internals.Logging.Serilog" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Logging_Serilog)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Internals.Logging.Serilog\Compze.Internals.Logging.Serilog.csproj" />
  </ItemGroup>
  <!-- Compze.Must — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Must)' == 'true'">
    <PackageReference Include="Compze.Must" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Must)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Must\Compze.Must.csproj" />
  </ItemGroup>
  <!-- Compze.xUnitBDD — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_xUnitBDD)' == 'true'">
    <PackageReference Include="Compze.xUnitBDD" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_xUnitBDD)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.xUnitBDD\Compze.xUnitBDD.csproj" />
  </ItemGroup>
</Project>