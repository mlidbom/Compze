    <ProjectReference Include="..\..\src\Compze.Typermedia.Hosting\Compze.Typermedia.Hosting.csproj" />
  </ItemGroup>
  <!-- Compze.Typermedia.Hosting.Testing — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Typermedia_Hosting_Testing)' == 'true'">
