<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <None Update="Testing\Xunit\TestUsingArgumentPassingFiveComponentsPCTAttribute">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>%(Filename)</TargetPath>
    </None>
    <None Update="Testing\Xunit\TestUsingArgumentPassingFourComponentsPCTAttribute">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>%(Filename)</TargetPath>
    </None>
    <None Update="Testing\Xunit\TestUsingArgumentPassingOneComponentsPCTAttribute">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>%(Filename)</TargetPath>
    </None>
    <None Update="Testing\Xunit\TestUsingArgumentPassingThreeComponentsPCTAttribute">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>%(Filename)</TargetPath>
    </None>
    <None Update="Testing\Xunit\TestUsingArgumentPassingTwoComponentsPCTAttribute">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>%(Filename)</TargetPath>
    </None>
    <None Update="Testing\Xunit\TestUsingNotArgumentPassingOneComponentsPCTAttribute">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>%(Filename)</TargetPath>
    </None>
    <None Update="Testing\Xunit\TestUsingNotArgumentPassingTwoComponentsPCTAttribute">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>%(Filename)</TargetPath>
    </None>
    <None Update="Testing\Xunit\TestUsingWildcards">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>%(Filename)</TargetPath>
    </None>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.0.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="xunit.v3" Version="3.1.0" />
  </ItemGroup>
  <!-- Compze.Core — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Core)' == 'true'">
    <PackageReference Include="Compze.Core" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Core)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Core\Compze.Core.csproj" />
  </ItemGroup>
  <!-- Compze.SystemCE.Staging — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_SystemCE_Staging)' == 'true'">
    <PackageReference Include="Compze.SystemCE.Staging" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_SystemCE_Staging)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.SystemCE.Staging\Compze.SystemCE.Staging.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.Testing.DbPool — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_DbPool)' == 'true'">
    <PackageReference Include="Compze.Utilities.Testing.DbPool" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_DbPool)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Utilities.Testing.DbPool\Compze.Utilities.Testing.DbPool.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.Testing.Must — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_Must)' == 'true'">
    <PackageReference Include="Compze.Utilities.Testing.Must" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_Must)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Utilities.Testing.Must\Compze.Utilities.Testing.Must.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.Testing.XUnit — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_XUnit)' == 'true'">
    <PackageReference Include="Compze.Utilities.Testing.XUnit" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_XUnit)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Utilities.Testing.XUnit\Compze.Utilities.Testing.XUnit.csproj" />
  </ItemGroup>
</Project>