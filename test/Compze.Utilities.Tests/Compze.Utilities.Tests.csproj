<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.0.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="xunit.v3" Version="3.1.0" />
  </ItemGroup>
  <!-- Compze.Core — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Core)' == 'true'">
    <PackageReference Include="Compze.Core" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Core)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Core\Compze.Core.csproj" />
  </ItemGroup>
  <!-- Compze.Must — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Must)' == 'true'">
    <PackageReference Include="Compze.Must" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Must)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Must\Compze.Must.csproj" />
  </ItemGroup>
  <!-- Compze.SystemCE.Internal — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_SystemCE_Internal)' == 'true'">
    <PackageReference Include="Compze.SystemCE.Internal" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_SystemCE_Internal)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.SystemCE.Internal\Compze.SystemCE.Internal.csproj" />
  </ItemGroup>
  <!-- Compze.xUnitBDD — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_xUnitBDD)' == 'true'">
    <PackageReference Include="Compze.xUnitBDD" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_xUnitBDD)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.xUnitBDD\Compze.xUnitBDD.csproj" />
  </ItemGroup>
</Project>