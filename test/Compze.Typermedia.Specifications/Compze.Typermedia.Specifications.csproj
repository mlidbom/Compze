<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.0.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="xunit.v3" Version="3.1.0" />
  </ItemGroup>
  <!-- Compze.Abstractions — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Abstractions)' == 'true'">
    <PackageReference Include="Compze.Abstractions" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Abstractions)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Abstractions\Compze.Abstractions.csproj" />
  </ItemGroup>
  <!-- Compze.Must — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Must)' == 'true'">
    <PackageReference Include="Compze.Must" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Must)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Must\Compze.Must.csproj" />
  </ItemGroup>
  <!-- Compze.Tessaging — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Tessaging)' == 'true'">
    <PackageReference Include="Compze.Tessaging" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Tessaging)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.Tessaging\Compze.Tessaging.csproj" />
  </ItemGroup>
  <!-- Compze.xUnitBDD — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_xUnitBDD)' == 'true'">
    <PackageReference Include="Compze.xUnitBDD" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_xUnitBDD)' != 'true'">
    <ProjectReference Include="..\..\src\Compze.xUnitBDD\Compze.xUnitBDD.csproj" />
  </ItemGroup>
</Project>