@@ -0,0 +1,16 @@
+﻿using Compze.Internals.SystemCE.CollectionsCE.GenericCE;
+using Compze.Internals.SystemCE.LinqCE;
+
+namespace Deskmancer.Core.SystemEX.CollectionsEX.GenericEX;
+
+static class DictionaryEX
+{
+   extension<TKey, TValue>(Dictionary<TKey, TValue> @this) where TKey : notnull
+   {
+      ///<summary>For each <see cref="KeyValuePair"/> in <paramref name="source"/> inster those values into <see cref="@this"/></summary>
+      public void Merge(IDictionary<TKey, TValue> source) => source.ForEach(it => @this[it.Key] = it.Value);
+
+      ///<summary>Remove all entries whose keys are not in <paramref name="keep"/></summary>
+      public void RemoveAllBut(ISet<TKey> keep) => @this.RemoveWhere(it => !keep.Contains(it.Key));
+   }
+}
