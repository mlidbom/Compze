+   static readonly Guid WindowOnAllDesktops = new("C2DDEA68-66F2-4CF9-8264-1BFD00FBBBAC");
+
+   extension(IReadOnlyList<HWND> @this)
+   {
+      public Dictionary<HWND, DesktopAffinity?> GetDesktopAffinities()
+      {
+         var affinities = new Dictionary<HWND, DesktopAffinity?>();
+         foreach(var handle in @this)
+         {
+            affinities[handle] = handle.GetEffectiveAffinity();
+         }
+
+         return affinities;
+      }
+   }
+
+   extension(HWND @this)
+   {
+      ///<summary>The role this window plays, recognized from its registered Win32 class — the magic class atoms stay confined here.</summary>
+      internal WindowKind Kind => @this.ToSafeHandle().Kind;
+
+      ///<summary>The affinity accounting for ownership: the window's own view's desktop, or — when it has no view of its own — its root owner's, where the OS keeps it. Null when neither has a stable desktop. Runs on the worker thread.</summary>
+      internal DesktopAffinity? GetEffectiveAffinity()
+      {
+         if(@this.GetDesktopAffinity() is {} own)
+         {
+            return own;
+         }
+
+         var rootOwner = @this.RootOwner();
+         return rootOwner == @this ? null : rootOwner.GetDesktopAffinity();
+      }
+
+      DesktopAffinity? GetDesktopAffinity()
+      {
+         if(@this.FollowsEveryDesktopByBand())
+         {
+            return DesktopAffinity.All; // an all-desktops "follow" window — COM-free
+         }
+
+         var id = @this.GetDesktopId();
+         if(id == null) return null;
+         if(id.Value.Value == WindowOnAllDesktops) return DesktopAffinity.All;
+         return DesktopAffinity.Specific(id.Value);
+      }
+
+      ///<summary>
+      /// Whether the window follows every virtual desktop by its z-order band — it sits in <see cref="WindowBand.SystemTools"/>,
+      /// the band an always-on-top Task Manager places itself in. Read COM-free from the undocumented <c>GetWindowBand</c>.
+      ///</summary>
+      ///<remarks>
+      /// False when the band can't be read. This runs over <em>every</em> live top-level window, many of them exotic system
+      /// windows the undocumented export was never meant for, and — during teardown — windows already closing; over those the
+      /// call does fail (observed). A window whose band we can't read is simply not treated as a follower; the shell then has
+      /// the say on its desktop. This is a genuine runtime condition (an undocumented call over arbitrary/dying windows we
+      /// cannot guarantee succeeds), not a guessed-at guard.
+      ///</remarks>
+      internal bool FollowsEveryDesktopByBand() => @this.Band == WindowBand.SystemTools;
+
+      ///<summary>The handle at the top of this window's owner chain. a window with no owner is its own root owner.</summary>
+      HWND RootOwner()
+      {
+         var rootOwner = @this;
+         for(var owner = rootOwner.ToSafeHandle().GetOwner(); owner != HWND.NULL; owner = rootOwner.ToSafeHandle().GetOwner())
+         {
+            rootOwner = owner;
+         }
+
+         return rootOwner;
+      }
+
+      WindowBand? Band => User32Undocumented.GetWindowBand(@this, out var band) ? (WindowBand)band : null;
+
+      DesktopId? GetDesktopId()
+      {
+         try
+         {
+            var id = DesktopManager.GetWindowDesktopId(@this);
+            if(id == Guid.Empty)
+            {
+               return null;
+            }
+
+            return new DesktopId(id);
+         }
+         catch(COMException viewNotRegistered) when(viewNotRegistered.HResult == TYPE_E_ELEMENTNOTFOUND)
+         {
+            return null;
+         }
+      }
+   }
+}
