diff --git a/Deskmancer.Core/Desktops/CacheExpirationHelper.cs b/Deskmancer.Core/Desktops/CacheExpirationHelper.cs
new file mode 100644
index 00000000..517dfbbb
--- /dev/null
+++ b/Deskmancer.Core/Desktops/CacheExpirationHelper.cs
@@ -0,0 +1,26 @@
+﻿using System.Diagnostics;
+
+namespace Deskmancer.Core.Desktops;
+
+class CacheExpirationHelper
+{
+   readonly TimeSpan _stalenessLimit;
+   readonly Stopwatch _sinceStart = Stopwatch.StartNew();
+   TimeSpan? _valuesRefreshedAt; // when Of last re-resolved the whole set; null = never/invalidated, so the next Of refreshes
+   public CacheExpirationHelper(TimeSpan stalenessLimit) => _stalenessLimit = stalenessLimit;
+
+   ///<summary>Whether cached values were last refreshed within the last <see cref="_stalenessLimit"/>.</summary>
+   bool ValuesFresh => _valuesRefreshedAt is {} at && _sinceStart.Elapsed - at <= _stalenessLimit;
+
+   public void MarkExpired() => _valuesRefreshedAt = null;
+   void MarkRefreshed() => _valuesRefreshedAt = _sinceStart.Elapsed;
+
+   public void RefreshIfStale(Action refresh)
+   {
+      if(!ValuesFresh)
+      {
+         refresh();
+         MarkRefreshed();
+      }
+   }
+}
