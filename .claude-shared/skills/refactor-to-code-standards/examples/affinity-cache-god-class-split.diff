@@ -0,0 +1,23 @@
+﻿using Compze.Underscore;
+using Deskmancer.Core.Windows.Registry;
+using Vanara.PInvoke;
+
+namespace Deskmancer.Core.VanaraEX.PInvokeEX.User32EX;
+
+public static class SafeHwndEX
+{
+   extension(User32.SafeHWND @this)
+   {
+      ///<summary>This window's registered Win32 class name (<c>Progman</c>, <c>WorkerW</c>, <c>Shell_TrayWnd</c>, …) — what its role is recognized from.</summary>
+      public string ClassName => @this.GetClassName(out var className)
+                                      .__(className);
+
+      ///<summary>The role this window plays, recognized from its registered Win32 class — the magic class atoms stay confined here.</summary>
+      public WindowKind Kind => @this.ClassName switch
+      {
+         "Shell_TrayWnd" or "Shell_SecondaryTrayWnd"            => WindowKind.Taskbar,
+         "Progman" or "WorkerW" or "Windows.UI.Core.CoreWindow" => WindowKind.ShellChrome,
+         _                                                      => WindowKind.UnknownPotentiallyApplication,
+      };
+   }
+}
