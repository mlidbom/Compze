+using Deskmancer.Core.Windows.Registry;
+using Vanara.PInvoke;
+
+namespace Deskmancer.Core.VanaraEX.PInvokeEX.User32EX;
+
+///<summary>Bridges a bare window handle into the form that carries the window operations.</summary>
+public static class HwndEX
+{
+   extension(HWND @this)
+   {
+      ///<summary>
+      /// Wrap a bare window handle so the things you can do to that window become ordinary methods you can reach by typing
+      /// <c>.</c> on it — <see cref="User32.SafeHWND.GetText"/>, <see cref="User32.SafeHWND.GetRect"/>, <see cref="User32.SafeHWND.Show"/> and the rest — instead of free functions you
+      /// have to already know exist and hand the handle to. The window stays owned by whoever created it; this only borrows
+      /// the handle to operate through it.
+      ///</summary>
+      ///<remarks>
+      /// A bare <see cref="HWND"/> is just a number; to act on the window you must hunt down the matching user32 function
+      /// and pass it the handle. Vanara's <see cref="User32.SafeHWND"/> turns that around: it auto-generates an instance
+      /// method for (almost) every user32 function whose first argument is a window handle, so the whole operation set is
+      /// discoverable from the object itself. That discoverability is the entire point of going through it.<br/>
+      /// <br/>
+      /// We pass <c>ownsHandle: false</c> because we did not create this window and must never destroy it. <see cref="User32.SafeHWND"/>
+      /// is a <see cref="System.Runtime.InteropServices.SafeHandle"/> whose job is normally to release what it holds; a
+      /// non-owning one skips that release entirely, so disposing it — or letting the finalizer reach it — leaves the real
+      /// window untouched. An implicit conversion back to <see cref="HWND"/> keeps the handle usable as identity.
+      ///</remarks>
+      public User32.SafeHWND ToSafeHandle() => new(@this, ownsHandle: false);
+   }
+}
