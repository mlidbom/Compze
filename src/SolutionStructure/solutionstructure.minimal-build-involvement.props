<!-- Common properties for all solution organization projects -->
<Project>
   <PropertyGroup>
      <TargetFramework>net10.0</TargetFramework>
      <IsPackable>false</IsPackable>
      <EnableDefaultItems>false</EnableDefaultItems>
   </PropertyGroup>

   <PropertyGroup>
      <BuildOutputExcludes>**/bin/**;**/obj/**;**/node_modules/**</BuildOutputExcludes>
      <CompzeExcludes>**/bin/**;**/obj/**;**/node_modules/**;**/*_NCrunchResults/**;**/nCrunchTemp_*/**</CompzeExcludes>
   </PropertyGroup>

   <ItemGroup>
      <None Include="../SolutionStructure/solutionstructure.minimal-build-involvement.props"/>
   </ItemGroup>
</Project>
