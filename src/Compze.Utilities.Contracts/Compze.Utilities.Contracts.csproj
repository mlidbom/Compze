      <Nullable>enable</Nullable>
   </PropertyGroup>
   <ItemGroup>
      <PackageReference Include="JetBrains.Annotations" Version="2025.2.4" />
      <PackageReference Include="NsDepCop" Version="2.6.0">
         <PrivateAssets>all</PrivateAssets>
         <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
   </ItemGroup>
   <ItemGroup>
      <ProjectReference Include="..\..\CircularLibraryDependencySourceRewriter\src\CircularLibraryDependencySourceRewriter\CircularLibraryDependencySourceRewriter.csproj" />
   </ItemGroup>
   <Import Project="..\..\CircularLibraryDependencySourceRewriter\src\CircularLibraryDependencySourceRewriter\CircularLibraryDependencySourceRewriter.targets" />
   <PropertyGroup>
      <InternalizeSourceFrom>..\Compze.Utilities</InternalizeSourceFrom>
      <InternalizeSourceTo>$(MSBuildProjectDirectory)\InternalizedSource</InternalizeSourceTo>
   </PropertyGroup>
</Project>