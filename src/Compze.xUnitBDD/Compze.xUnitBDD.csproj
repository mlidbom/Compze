<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <IsTestProject>false</IsTestProject>
    <Version>0.5.0-beta</Version>
    <Description>BDD-style specification testing for xUnit v3. Provides [XF] (ExclusiveFact) attribute that prevents inherited tests from running in child classes, enabling nested class hierarchies that read like executable specifications without test explosion.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="xunit.v3.extensibility.core" Version="3.1.0" />
  </ItemGroup>
  <!-- Compze.xUnit — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_xUnit)' == 'true'">
    <PackageReference Include="Compze.xUnit" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_xUnit)' != 'true'">
    <ProjectReference Include="..\Compze.xUnit\Compze.xUnit.csproj" />
  </ItemGroup>
</Project>