<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <IsTestProject>false</IsTestProject>
    <Version>0.1.1-alpha</Version>
    <Description>Internal shared xUnit extensibility foundation for the Compze framework. Not intended for direct consumption — depend on Compze.xUnitBDD or Compze.xUnit.ComponentCombinations instead.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="xunit.v3.extensibility.core" Version="3.1.0" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Compze.xUnitBDD" />
    <InternalsVisibleTo Include="Compze.xUnitMatrix" />
  </ItemGroup>
</Project>
