<Project Sdk="Microsoft.NET.Sdk">

   <PropertyGroup>
      <TargetFramework>net8.0</TargetFramework>
      <Nullable>enable</Nullable>
   </PropertyGroup>

   <PropertyGroup>
      <RootNamespace>Compze.DependencyInjection</RootNamespace>
      <NuGetAuditMode>direct</NuGetAuditMode>
      <AnalysisLevel>latest-all</AnalysisLevel>
      <RunAnalyzersDuringLiveAnalysis>False</RunAnalyzersDuringLiveAnalysis>
   </PropertyGroup>

   <ItemGroup>
      <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.9" />
      <PackageReference Include="JetBrains.Annotations" Version="2025.2.2">
         <PrivateAssets>all</PrivateAssets>
      </PackageReference>
   </ItemGroup>

   <ItemGroup>
     <ProjectReference Include="..\Compze.InternalUtilities\Compze.Utilities.csproj" />
   </ItemGroup>

   <ItemGroup>
      <InternalsVisibleTo Include="Compze.DependencyInjection.Microsoft" />
      <InternalsVisibleTo Include="Compze.DependencyInjection.SimpleInjector" />
      <InternalsVisibleTo Include="Compze.Persistence.InMemory" />
      <InternalsVisibleTo Include="Compze.Persistence.MicrosoftSql" />
      <InternalsVisibleTo Include="Compze.Persistence.MySql" />
      <InternalsVisibleTo Include="Compze.Persistence.PostgreSql" />
      <InternalsVisibleTo Include="Compze.Tessaging" />
      <InternalsVisibleTo Include="Compze.Testing" />
   </ItemGroup>
</Project>
