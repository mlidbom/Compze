<Project Sdk="Microsoft.NET.Sdk">

   <PropertyGroup>
      <TargetFramework>net8.0</TargetFramework>
      <Nullable>enable</Nullable>
   </PropertyGroup>

   <PropertyGroup>
      <RootNamespace>Compze</RootNamespace>
      <NuGetAuditMode>direct</NuGetAuditMode>
      <AnalysisLevel>latest-all</AnalysisLevel>
      <RunAnalyzersDuringLiveAnalysis>False</RunAnalyzersDuringLiveAnalysis>
   </PropertyGroup>

   <ItemGroup>
       <ProjectReference Include="..\Compze.Abstractions\Compze.Abstractions.csproj" />
      <ProjectReference Include="..\Compze.Logging\Compze.Logging.csproj" />
      <ProjectReference Include="..\Compze.Persistence.Common\Compze.Persistence.Common.csproj" />
      <ProjectReference Include="..\Compze.Serialization\Compze.Serialization.csproj" />
      <ProjectReference Include="..\Compze.Tessaging.Common\Compze.Tessaging.Common.csproj" />
      <ProjectReference Include="..\Compze.Teventive\Compze.Teventive.csproj" />
   </ItemGroup>

   <ItemGroup>
       <PackageReference Include="JetBrains.Annotations" Version="2025.2.2">
           <PrivateAssets>all</PrivateAssets>
       </PackageReference>
      <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
   </ItemGroup>

   <ItemGroup>
      <PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="9.0.9" />
   </ItemGroup>

   <ItemGroup>
      <InternalsVisibleTo Include="Compze.Tessaging" />
      <InternalsVisibleTo Include="Compze.Persistence" />
      <InternalsVisibleTo Include="Compze.Tests.Integration.Internals" />
   </ItemGroup>

</Project>