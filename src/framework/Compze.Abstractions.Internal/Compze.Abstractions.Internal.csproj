<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<Nullable>enable</Nullable>
		<!--todo: get this into all our csproj files when we start publishing, to guarantee semantic versioning <PackageValidationBaselineVersion>1.0.0.0</PackageValidationBaselineVersion>-->
	</PropertyGroup>

	<PropertyGroup>
		<RootNamespace>Compze.Abstractions.Internal</RootNamespace>
		<NuGetAuditMode>direct</NuGetAuditMode>
		<AnalysisLevel>latest-all</AnalysisLevel>
		<RunAnalyzersDuringLiveAnalysis>False</RunAnalyzersDuringLiveAnalysis>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\Compze.Abstractions\Compze.Abstractions.csproj" />
		<ProjectReference Include="..\Compze.EventStore.Abstractions\Compze.EventStore.Abstractions.csproj" />
		<ProjectReference Include="..\Compze.InternalUtilities\Compze.Utilities.csproj" />
	</ItemGroup>

	<ItemGroup>
      <InternalsVisibleTo Include="Compze.Common" />
      <InternalsVisibleTo Include="Compze.DocumentDb" />
      <InternalsVisibleTo Include="Compze.DocumentDb.MicrosoftSql" />
      <InternalsVisibleTo Include="Compze.DocumentDb.MySql" />
      <InternalsVisibleTo Include="Compze.DocumentDb.PostgreSql" />
      <InternalsVisibleTo Include="Compze.EventStore" />
      <InternalsVisibleTo Include="Compze.EventStore.MySql" />
      <InternalsVisibleTo Include="Compze.Persistence" />
      <InternalsVisibleTo Include="Compze.Persistence.InMemory" />
      <InternalsVisibleTo Include="Compze.Serialization" />
      <InternalsVisibleTo Include="Compze.Tessaging" />
      <InternalsVisibleTo Include="Compze.Tests.Unit.Internals" />
      <InternalsVisibleTo Include="Compze.Teventive" />
	</ItemGroup>

</Project>
