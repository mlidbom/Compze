<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<Nullable>enable</Nullable>
		<!--todo: get this into all our csproj files when we start publishing, to guarantee semantic versioning <PackageValidationBaselineVersion>1.0.0.0</PackageValidationBaselineVersion>-->
	</PropertyGroup>

	<PropertyGroup>
		<RootNamespace>Compze.Tessaging.Common</RootNamespace>
		<NuGetAuditMode>direct</NuGetAuditMode>
		<AnalysisLevel>latest-all</AnalysisLevel>
		<RunAnalyzersDuringLiveAnalysis>False</RunAnalyzersDuringLiveAnalysis>
	</PropertyGroup>

	<ItemGroup>
	  <ProjectReference Include="..\Compze.Abstractions\Compze.Abstractions.csproj" />
	  <ProjectReference Include="..\Compze.EventStore.Abstractions\Compze.EventStore.Abstractions.csproj" />
	  <ProjectReference Include="..\Compze.InternalUtilities\Compze.Utilities.csproj" />
	  <ProjectReference Include="..\Compze.Teventive.Abstractions\Compze.Teventive.Abstractions.csproj" />
	</ItemGroup>

	<ItemGroup>
      <InternalsVisibleTo Include="Compze.EventStore" />
      <InternalsVisibleTo Include="Compze.Tessaging" />
      <InternalsVisibleTo Include="Compze.Tests.Integration.Internals" />
      <InternalsVisibleTo Include="Compze.Tests.Unit.Internals" />
      <InternalsVisibleTo Include="Compze.Teventive" />
	</ItemGroup>

</Project>
