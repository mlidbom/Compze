<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.*" />
    <PackageReference Include="xunit.v3" Version="*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="*" />
  </ItemGroup>
  <PropertyGroup>
    <DefaultItemExcludes>$(DefaultItemExcludes);input_source\**;output_source\**;batch_output_source\**</DefaultItemExcludes>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Compze.Build.InternalizedSourceReferences\Compze.Build.InternalizedSourceReferences.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.Testing.Must — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_Must)' == 'true'">
    <PackageReference Include="Compze.Utilities.Testing.Must" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_Must)' != 'true'">
    <ProjectReference Include="..\..\..\Compze.Utilities.Testing.Must\Compze.Utilities.Testing.Must.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.Testing.XUnit — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_XUnit)' == 'true'">
    <PackageReference Include="Compze.Utilities.Testing.XUnit" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_XUnit)' != 'true'">
    <ProjectReference Include="..\..\..\Compze.Utilities.Testing.XUnit\Compze.Utilities.Testing.XUnit.csproj" />
  </ItemGroup>
</Project>