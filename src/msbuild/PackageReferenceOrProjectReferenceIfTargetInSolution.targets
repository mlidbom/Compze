<Project>
   <!--
      Conditional ProjectReference → PackageReference Conversion

      Converts ProjectReference items marked with ConvertToPackageWhenNotInSolution="true"
      into PackageReference items when the referenced project is not part of the current solution.

      Usage in .csproj files:
         <ProjectReference Include="../Compze.Core/Compze.Core.csproj"
                           ConvertToPackageWhenNotInSolution="true"
                           PackageFallbackVersion="*-*" />

      When building with a solution containing Compze.Core → stays as ProjectReference
      When building without a solution or without Compze.Core → becomes PackageReference
      Under NCrunch → always stays as ProjectReference (NCrunch handles them natively)
   -->

   <!-- Under NCrunch, skip all conversion — NCrunch handles real ProjectReferences natively
        and builds in isolated workspaces where our conversion would interfere. -->

   <!-- Read the solution file content for project membership detection (non-NCrunch only).
        $(SolutionPath) is set by Visual Studio, Rider, VS Code (C# Dev Kit),
        and 'dotnet build *.slnx'. It is '*Undefined*' when not set. -->
   <PropertyGroup Condition="'$(NCrunch)' != '1' and '$(SolutionPath)' != '' and '$(SolutionPath)' != '*Undefined*' and Exists('$(SolutionPath)')">
      <_PkgOrPrj_SlnxContent>$([System.IO.File]::ReadAllText('$(SolutionPath)'))</_PkgOrPrj_SlnxContent>
   </PropertyGroup>

   <!-- Extract convertible ProjectReferences (non-NCrunch only) -->
   <ItemGroup Condition="'$(NCrunch)' != '1'">
      <_PkgOrPrj_Convertible Include="@(ProjectReference->WithMetadataValue('ConvertToPackageWhenNotInSolution', 'true'))" />
   </ItemGroup>

   <!-- With solution context: tag which convertible items are in the solution -->
   <ItemGroup Condition="'$(NCrunch)' != '1' and '$(_PkgOrPrj_SlnxContent)' != ''">
      <_PkgOrPrj_Convertible Update="@(_PkgOrPrj_Convertible)">
         <_IsInSolution>$(_PkgOrPrj_SlnxContent.Contains('%(Filename).csproj'))</_IsInSolution>
      </_PkgOrPrj_Convertible>
   </ItemGroup>

   <!-- Separate not-in-solution items -->
   <ItemGroup Condition="'$(NCrunch)' != '1' and '$(_PkgOrPrj_SlnxContent)' != ''">
      <_PkgOrPrj_ToConvert Include="@(_PkgOrPrj_Convertible->WithMetadataValue('_IsInSolution', 'False'))" />
   </ItemGroup>

   <!-- Convert not-in-solution items: remove ProjectReference, add PackageReference.
        Set _PackageName and Version metadata, create intermediary items with package-name identity,
        then set Version on those items before creating PackageReference. -->
   <ItemGroup Condition="'$(NCrunch)' != '1' and '$(_PkgOrPrj_SlnxContent)' != ''">
      <_PkgOrPrj_ToConvert Update="@(_PkgOrPrj_ToConvert)">
         <_PackageName>%(Filename)</_PackageName>
      </_PkgOrPrj_ToConvert>
   </ItemGroup>

   <ItemGroup Condition="'$(NCrunch)' != '1' and '$(_PkgOrPrj_SlnxContent)' != ''">
      <ProjectReference Remove="@(_PkgOrPrj_ToConvert)" />
   </ItemGroup>

   <!-- Create PackageReference items: use _PackageName as identity.
        Transforms strip metadata, so use Update to set Version afterwards. -->
   <ItemGroup Condition="'$(NCrunch)' != '1' and '$(_PkgOrPrj_SlnxContent)' != ''">
      <PackageReference Include="@(_PkgOrPrj_ToConvert->'%(_PackageName)')" />
   </ItemGroup>

   <ItemGroup Condition="'$(NCrunch)' != '1' and '$(_PkgOrPrj_SlnxContent)' != ''">
      <PackageReference Update="@(_PkgOrPrj_ToConvert->'%(_PackageName)')">
         <Version>*-*</Version>
      </PackageReference>
   </ItemGroup>

   <!-- No solution context (non-NCrunch): convert ALL convertible items to PackageReference -->
   <ItemGroup Condition="'$(NCrunch)' != '1' and '$(_PkgOrPrj_SlnxContent)' == ''">
      <_PkgOrPrj_Convertible Update="@(_PkgOrPrj_Convertible)">
         <_PackageName>%(Filename)</_PackageName>
      </_PkgOrPrj_Convertible>
   </ItemGroup>

   <ItemGroup Condition="'$(NCrunch)' != '1' and '$(_PkgOrPrj_SlnxContent)' == ''">
      <ProjectReference Remove="@(_PkgOrPrj_Convertible)" />
   </ItemGroup>

   <ItemGroup Condition="'$(NCrunch)' != '1' and '$(_PkgOrPrj_SlnxContent)' == ''">
      <PackageReference Include="@(_PkgOrPrj_Convertible->'%(_PackageName)')" />
   </ItemGroup>

   <ItemGroup Condition="'$(NCrunch)' != '1' and '$(_PkgOrPrj_SlnxContent)' == ''">
      <PackageReference Update="@(_PkgOrPrj_Convertible->'%(_PackageName)')">
         <Version>*-*</Version>
      </PackageReference>
   </ItemGroup>

   <!-- Clean up temporary items -->
   <ItemGroup Condition="'$(NCrunch)' != '1'">
      <_PkgOrPrj_Convertible Remove="@(_PkgOrPrj_Convertible)" />
      <_PkgOrPrj_ToConvert Remove="@(_PkgOrPrj_ToConvert)" />
   </ItemGroup>
</Project>
