<Project>
	<!-- Copy TestUsingPluggableComponentCombinations to test project output -->
	<ItemGroup>
		<Content Include="$(MSBuildThisFileDirectory)..\TestUsingPluggableComponentCombinations">
			<Link>TestUsingPluggableComponentCombinations</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
	</ItemGroup>
</Project>
