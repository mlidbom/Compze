<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.1.0-alpha.3</Version>
    <Description>Core utilities for the Compze framework including dependency injection abstractions, system extensions, and threading helpers.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="NsDepCop" Version="2.6.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="SystemCE\TextCE\" />
    <Folder Include="SystemCE\ThreadingCE\Async\" />
  </ItemGroup>
  <!-- Compze.Functional — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Functional)' == 'true'">
    <PackageReference Include="Compze.Functional" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Functional)' != 'true'">
    <ProjectReference Include="..\Compze.Functional\Compze.Functional.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.Contracts — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Contracts)' == 'true'">
    <PackageReference Include="Compze.Utilities.Contracts" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Contracts)' != 'true'">
    <ProjectReference Include="..\Compze.Utilities.Contracts\Compze.Utilities.Contracts.csproj" />
  </ItemGroup>
</Project>