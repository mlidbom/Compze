<Project>
	<PropertyGroup>
		<EnablePackageValidation>true</EnablePackageValidation>
	</PropertyGroup>
	
	<!-- Ensure TestUsingPluggableComponentCombinations.config exists by copying from example if needed -->
	<Target Name="EnsurePluggableComponentsConfig" BeforeTargets="Build">
		<PropertyGroup>
			<PluggableComponentsConfig>$(MSBuildThisFileDirectory)TestUsingPluggableComponentCombinations.config</PluggableComponentsConfig>
			<PluggableComponentsExample>$(MSBuildThisFileDirectory)TestUsingPluggableComponentCombinations.config.example</PluggableComponentsExample>
		</PropertyGroup>
		<Copy SourceFiles="$(PluggableComponentsExample)" 
		      DestinationFiles="$(PluggableComponentsConfig)" 
		      Condition="!Exists('$(PluggableComponentsConfig)') AND Exists('$(PluggableComponentsExample)')" 
		      SkipUnchangedFiles="true">
			<Output TaskParameter="CopiedFiles" ItemName="CopiedConfigFile" />
		</Copy>
		<Message Text="Created TestUsingPluggableComponentCombinations.config from example file" 
		         Condition="'@(CopiedConfigFile)' != ''" 
		         Importance="high" />
	</Target>
</Project>