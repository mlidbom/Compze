<Project>
	<PropertyGroup>
		<EnablePackageValidation>true</EnablePackageValidation>
	</PropertyGroup>
	
	<!-- Ensure TestUsingPluggableComponentCombinations exists by copying from example if needed -->
	<Target Name="EnsurePluggableComponentsConfig" BeforeTargets="Build">
		<PropertyGroup>
			<PluggableComponentsConfig>$(MSBuildThisFileDirectory)TestUsingPluggableComponentCombinations</PluggableComponentsConfig>
			<PluggableComponentsExample>$(MSBuildThisFileDirectory)TestUsingPluggableComponentCombinations.example</PluggableComponentsExample>
		</PropertyGroup>
		<Copy SourceFiles="$(PluggableComponentsExample)" 
		      DestinationFiles="$(PluggableComponentsConfig)" 
		      Condition="!Exists('$(PluggableComponentsConfig)') AND Exists('$(PluggableComponentsExample)')" 
		      SkipUnchangedFiles="true">
			<Output TaskParameter="CopiedFiles" ItemName="CopiedConfigFile" />
		</Copy>
		<Message Text="Created TestUsingPluggableComponentCombinations from example file" 
		         Condition="'@(CopiedConfigFile)' != ''" 
		         Importance="high" />
	</Target>
	
	<!-- Automatically copy test configuration files to output for test projects -->
	<!-- Matches test projects but excludes non-test support libraries -->
   <ItemGroup Condition="($(MSBuildProjectDirectory.Contains('$(MSBuildDirectorySeparatorChar)Tests$(MSBuildDirectorySeparatorChar)')) OR $(MSBuildProjectName.Contains('Test')) OR $(MSBuildProjectDirectory.Contains('ScratchPad'))) AND !$(MSBuildProjectName.Contains('.Testing'))">
		<Content Include="$(MSBuildThisFileDirectory)TestUsingPluggableComponentCombinations">
			<Link>TestUsingPluggableComponentCombinations</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<Visible>false</Visible>
		</Content>
		<Content Include="$(MSBuildThisFileDirectory)Compze\test-common-appsettings.json">
			<Link>appsettings.json</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<Visible>false</Visible>
		</Content>
		<Compile Include="$(MSBuildThisFileDirectory)Tests\SuppressFluentAssertionsLicenceMessageModuleInitializer.cs">
			<Link>SuppressFluentAssertionsLicenceMessageModuleInitializer.cs</Link>
			<Visible>false</Visible>
		</Compile>
	</ItemGroup>
</Project>