<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.1.0-alpha.1</Version>
    <Description>MySQL database pool support for Compze integration testing.</Description>
  </PropertyGroup>
  <!-- Compze.Sql.MySql — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Sql_MySql)' == 'true'">
    <PackageReference Include="Compze.Sql.MySql" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Sql_MySql)' != 'true'">
    <ProjectReference Include="..\Compze.Sql.MySql\Compze.Sql.MySql.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.Testing.DbPool — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_DbPool)' == 'true'">
    <PackageReference Include="Compze.Utilities.Testing.DbPool" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_DbPool)' != 'true'">
    <ProjectReference Include="..\Compze.Utilities.Testing.DbPool\Compze.Utilities.Testing.DbPool.csproj" />
  </ItemGroup>
</Project>