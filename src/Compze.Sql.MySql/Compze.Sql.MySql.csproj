<Project Sdk="Microsoft.NET.Sdk">
   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
      <Nullable>enable</Nullable>
      <Version>0.1.0-alpha.3</Version>
      <Description>MySQL database support for the Compze framework.</Description>
   </PropertyGroup>
   <ItemGroup>
      <PackageReference Include="MySql.Data" Version="9.4.0" />
      <PackageReference Include="NsDepCop" Version="2.6.0">
         <PrivateAssets>all</PrivateAssets>
         <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Core)' == 'true'">
      <PackageReference Include="Compze.Core" Version="0.1.0-alpha.3" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Core)' != 'true'">
      <ProjectReference Include="..\Compze.Core\Compze.Core.csproj" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Sql_Common)' == 'true'">
      <PackageReference Include="Compze.Sql.Common" Version="0.1.0-alpha.3" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Sql_Common)' != 'true'">
      <ProjectReference Include="..\Compze.Sql.Common\Compze.Sql.Common.csproj" />
   </ItemGroup>
</Project>