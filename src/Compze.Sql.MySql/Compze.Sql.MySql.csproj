<Project Sdk="Microsoft.NET.Sdk">
   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
      <Nullable>enable</Nullable>
      <Version>0.1.0-alpha.3</Version>
      <Description>MySQL database support for the Compze framework.</Description>
   </PropertyGroup>
   <ItemGroup>
      <ProjectReference Include="../Compze.Core/Compze.Core.csproj" ConvertToPackageWhenNotInSolution="true" PackageFallbackVersion="*-*" />
      <ProjectReference Include="../Compze.Sql.Common/Compze.Sql.Common.csproj" ConvertToPackageWhenNotInSolution="true" PackageFallbackVersion="*-*" />
   </ItemGroup>
   <ItemGroup>
      <PackageReference Include="MySql.Data" Version="9.4.0" />
      <PackageReference Include="NsDepCop" Version="2.6.0">
         <PrivateAssets>all</PrivateAssets>
         <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
   </ItemGroup>
</Project>