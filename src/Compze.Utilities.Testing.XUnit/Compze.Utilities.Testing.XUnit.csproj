<Project Sdk="Microsoft.NET.Sdk">
   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
      <Nullable>enable</Nullable>
      <IsTestProject>false</IsTestProject>
      <Version>0.1.0-alpha.3</Version>
      <Description>xUnit testing utilities and attributes for the Compze framework.</Description>
   </PropertyGroup>
   <ItemGroup>
      <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.0.0" />
      <PackageReference Include="xunit.v3.extensibility.core" Version="3.1.0" />
      <PackageReference Include="NsDepCop" Version="2.6.0">
         <PrivateAssets>all</PrivateAssets>
         <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Contracts)' == 'true'">
      <PackageReference Include="Compze.Utilities.Contracts" Version="0.1.0-alpha.3" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Contracts)' != 'true'">
      <ProjectReference Include="..\Compze.Utilities.Contracts\Compze.Utilities.Contracts.csproj" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Functional)' == 'true'">
      <PackageReference Include="Compze.Utilities.Functional" Version="0.1.0-alpha.3" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Functional)' != 'true'">
      <ProjectReference Include="..\Compze.Utilities.Functional\Compze.Utilities.Functional.csproj" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_DependencyInjection)' == 'true'">
      <PackageReference Include="Compze.Utilities.DependencyInjection" Version="0.1.0-alpha.3" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_DependencyInjection)' != 'true'">
      <ProjectReference Include="..\Compze.Utilities.DependencyInjection\Compze.Utilities.DependencyInjection.csproj" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Logging)' == 'true'">
      <PackageReference Include="Compze.Utilities.Logging" Version="0.1.0-alpha.3" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Logging)' != 'true'">
      <ProjectReference Include="..\Compze.Utilities.Logging\Compze.Utilities.Logging.csproj" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_SystemCE)' == 'true'">
      <PackageReference Include="Compze.Utilities.SystemCE" Version="0.1.0-alpha.3" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_SystemCE)' != 'true'">
      <ProjectReference Include="..\Compze.Utilities.SystemCE\Compze.Utilities.SystemCE.csproj" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_SystemCE_ThreadingCE)' == 'true'">
      <PackageReference Include="Compze.Utilities.SystemCE.ThreadingCE" Version="0.1.0-alpha.3" />
   </ItemGroup>
   <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_SystemCE_ThreadingCE)' != 'true'">
      <ProjectReference Include="..\Compze.Utilities.SystemCE.ThreadingCE\Compze.Utilities.SystemCE.ThreadingCE.csproj" />
   </ItemGroup>
</Project>