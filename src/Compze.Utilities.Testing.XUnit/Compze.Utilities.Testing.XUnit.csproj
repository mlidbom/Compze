<Project Sdk="Microsoft.NET.Sdk">
   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
      <Nullable>enable</Nullable>
      <IsTestProject>false</IsTestProject>
      <Version>0.1.0-alpha.3</Version>
      <Description>xUnit testing utilities and attributes for the Compze framework.</Description>
   </PropertyGroup>
   <ItemGroup>
      <ProjectReference Include="../Compze.Utilities.Contracts/Compze.Utilities.Contracts.csproj" ConvertToPackageWhenNotInSolution="true" PackageFallbackVersion="*-*" />
      <ProjectReference Include="../Compze.Utilities.Functional/Compze.Utilities.Functional.csproj" ConvertToPackageWhenNotInSolution="true" PackageFallbackVersion="*-*" />
      <ProjectReference Include="../Compze.Utilities.DependencyInjection/Compze.Utilities.DependencyInjection.csproj" ConvertToPackageWhenNotInSolution="true" PackageFallbackVersion="*-*" />
      <ProjectReference Include="../Compze.Utilities.Logging/Compze.Utilities.Logging.csproj" ConvertToPackageWhenNotInSolution="true" PackageFallbackVersion="*-*" />
      <ProjectReference Include="../Compze.Utilities.SystemCE/Compze.Utilities.SystemCE.csproj" ConvertToPackageWhenNotInSolution="true" PackageFallbackVersion="*-*" />
      <ProjectReference Include="../Compze.Utilities.SystemCE.ThreadingCE/Compze.Utilities.SystemCE.ThreadingCE.csproj" ConvertToPackageWhenNotInSolution="true" PackageFallbackVersion="*-*" />
   </ItemGroup>
   <ItemGroup>
      <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.0.0" />
      <PackageReference Include="xunit.v3.extensibility.core" Version="3.1.0" />
      <PackageReference Include="NsDepCop" Version="2.6.0">
         <PrivateAssets>all</PrivateAssets>
         <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
   </ItemGroup>
</Project>