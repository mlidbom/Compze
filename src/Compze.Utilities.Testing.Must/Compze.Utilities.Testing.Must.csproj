<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.2.0-alpha.1</Version>
    <Description>Fluent assertion library for Compze testing.</Description>
  </PropertyGroup>
  <ItemGroup>
    <AdditionalFiles Include="config.nsdepcop" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="DiffPlex" Version="1.9.0" />
  </ItemGroup>
  <!-- Compze.Contracts — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Contracts)' == 'true'">
    <PackageReference Include="Compze.Contracts" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Contracts)' != 'true'">
    <ProjectReference Include="..\Compze.Contracts\Compze.Contracts.csproj" />
  </ItemGroup>
  <!-- Compze.Functional — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Functional)' == 'true'">
    <PackageReference Include="Compze.Functional" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Functional)' != 'true'">
    <ProjectReference Include="..\Compze.Functional\Compze.Functional.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.DependencyInjection — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_DependencyInjection)' == 'true'">
    <PackageReference Include="Compze.Utilities.DependencyInjection" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_DependencyInjection)' != 'true'">
    <ProjectReference Include="..\Compze.Utilities.DependencyInjection\Compze.Utilities.DependencyInjection.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.Logging — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Logging)' == 'true'">
    <PackageReference Include="Compze.Utilities.Logging" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Logging)' != 'true'">
    <ProjectReference Include="..\Compze.Utilities.Logging\Compze.Utilities.Logging.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.SystemCE — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_SystemCE)' == 'true'">
    <PackageReference Include="Compze.Utilities.SystemCE" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_SystemCE)' != 'true'">
    <ProjectReference Include="..\Compze.Utilities.SystemCE\Compze.Utilities.SystemCE.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.SystemCE.ThreadingCE — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_SystemCE_ThreadingCE)' == 'true'">
    <PackageReference Include="Compze.Utilities.SystemCE.ThreadingCE" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_SystemCE_ThreadingCE)' != 'true'">
    <ProjectReference Include="..\Compze.Utilities.SystemCE.ThreadingCE\Compze.Utilities.SystemCE.ThreadingCE.csproj" />
  </ItemGroup>
</Project>