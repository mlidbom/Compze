<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.3.0-alpha</Version>
    <!-- TODO:docs: Remove once all public API members have XML documentation comments -->
    <NoWarn>CS1591</NoWarn>
    <Description>For Compze internal use only. Do not take a direct dependency on this package. SQLite inbox/outbox backend for Compze messaging.</Description>
    <PackageTags>compze;messaging;inbox;outbox;sqlite</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.1" />
  </ItemGroup>
  <!-- Compze.Internals.Sql.Sqlite — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Sql_Sqlite)' == 'true'">
    <PackageReference Include="Compze.Internals.Sql.Sqlite" Version="*-*" />
  </ItemGroup>
  <!-- Compze.Sql.Sqlite — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Sql_Sqlite)' == 'true'">
    <PackageReference Include="Compze.Sql.Sqlite" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Sql_Sqlite)' != 'true'">
    <ProjectReference Include="..\Compze.Sql.Sqlite\Compze.Sql.Sqlite.csproj" />
  </ItemGroup>
  <!-- Compze.Tessaging — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Tessaging)' == 'true'">
    <PackageReference Include="Compze.Tessaging" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Tessaging)' != 'true'">
    <ProjectReference Include="..\Compze.Tessaging\Compze.Tessaging.csproj" />
  </ItemGroup>
  <!-- Compze.Threading.Interprocess — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Threading_Interprocess)' == 'true'">
    <PackageReference Include="Compze.Threading.Interprocess" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Threading_Interprocess)' != 'true'">
    <ProjectReference Include="..\Compze.Threading.Interprocess\Compze.Threading.Interprocess.csproj" />
  </ItemGroup>
  <!-- Compze.TypeIdentifiers.Interning — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_TypeIdentifiers_Interning)' == 'true'">
    <PackageReference Include="Compze.TypeIdentifiers.Interning" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_TypeIdentifiers_Interning)' != 'true'">
    <ProjectReference Include="..\Compze.TypeIdentifiers.Interning\Compze.TypeIdentifiers.Interning.csproj" />
  </ItemGroup>
  <!-- Compze.TypeIdentifiers.Interning.Sqlite — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_TypeIdentifiers_Interning_Sqlite)' == 'true'">
    <PackageReference Include="Compze.TypeIdentifiers.Interning.Sqlite" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_TypeIdentifiers_Interning_Sqlite)' != 'true'">
    <ProjectReference Include="..\Compze.TypeIdentifiers.Interning.Sqlite\Compze.TypeIdentifiers.Interning.Sqlite.csproj" />
  </ItemGroup>
</Project>