<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.2.1-alpha</Version>
    <!-- TODO: Remove once all public API members have XML documentation comments -->
    <NoWarn>CS1591</NoWarn>
    <Description>For Compze internal use only. Do not take a direct dependency on this package</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Npgsql" Version="9.0.4" />
  </ItemGroup>
  <!-- Compze.Core — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Core)' == 'true'">
    <PackageReference Include="Compze.Core" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Core)' != 'true'">
    <ProjectReference Include="..\Compze.Core\Compze.Core.csproj" />
  </ItemGroup>
  <!-- Compze.Internals.Sql.Common — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Sql_Common)' == 'true'">
    <PackageReference Include="Compze.Internals.Sql.Common" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Sql_Common)' != 'true'">
    <ProjectReference Include="..\Compze.Internals.Sql.Common\Compze.Internals.Sql.Common.csproj" />
  </ItemGroup>
  <!-- Compze.TypeIdentifiers.Interning — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_TypeIdentifiers_Interning)' == 'true'">
    <PackageReference Include="Compze.TypeIdentifiers.Interning" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_TypeIdentifiers_Interning)' != 'true'">
    <ProjectReference Include="..\Compze.TypeIdentifiers.Interning\Compze.TypeIdentifiers.Interning.csproj" />
  </ItemGroup>
</Project>