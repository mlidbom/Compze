<Project Sdk="Microsoft.NET.Sdk">
   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
      <Nullable>enable</Nullable>
      <Version>0.1.0-alpha.3</Version>
      <Description>PostgreSQL database support for the Compze framework.</Description>
   </PropertyGroup>
   <ItemGroup>
      <FlexiReference Include="Compze.Core" ProjectPath="..\Compze.Core\Compze.Core.csproj" Version="$(CompzePackageVersion)" />
      <FlexiReference Include="Compze.Sql.Common" ProjectPath="..\Compze.Sql.Common\Compze.Sql.Common.csproj" Version="$(CompzePackageVersion)" />
   </ItemGroup>
   <ItemGroup>
      <PackageReference Include="Npgsql" Version="9.0.4" />
      <PackageReference Include="NsDepCop" Version="2.6.0">
         <PrivateAssets>all</PrivateAssets>
         <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
   </ItemGroup>
</Project>