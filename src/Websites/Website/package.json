{
  "scripts": {
    "browser-livereload": "browser-sync start --server _site/ --port 8080 --files='_site/*'",
    "live-server": "live-server --port=8080 --host=localhost --watch=_site/ --open=_site/ --quiet",
    "watch": "npm-watch build",
    "prebuild": "pwsh -NoProfile -File Ensure-CoLocatedDocsJunctions.ps1",
    "build": "docfx build",
    "build-full": "docfx",
    "watch-site-only": "npm-watch build-site-only",
    "prebuild-site-only": "pwsh -NoProfile -File Ensure-CoLocatedDocsJunctions.ps1",
    "build-site-only": "docfx build docfx-site-only.json"
  },
  "_###_important_comment_###_": "remember the npm-watch magic incantation, the name of the watch is the same as the name of the script the watch will run when it detects a change",
  "watch": {
    "build": {
      "patterns": [
        "./*"
      ],
      "extensions": "md,yml,css,cs,js",
      "quiet": false,
      "ignore": "_site/*",
      "delay": 500
    },
    "build-site-only": {
      "patterns": [
        "./*"
      ],
      "extensions": "md,yml,css,cs,js",
      "quiet": false,
      "ignore": "_site/*",
      "delay": 500
    }
  },
  "devDependencies": {
    "browser-sync": "^3.0.3",
    "live-server": "^1.2.2",
    "npm-watch": "^0.13.0"
  }
}
