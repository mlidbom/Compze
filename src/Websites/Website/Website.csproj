<Project Sdk="Microsoft.NET.Sdk.Web">
    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
        <WarnOnPackingNonPackableProject>false</WarnOnPackingNonPackableProject>
    </PropertyGroup>
    <ItemGroup>
        <Compile Remove="_site\**" />
        <Compile Remove="api\**" />
    </ItemGroup>
    <ItemGroup>
        <EmbeddedResource Remove="_site\**" />
        <EmbeddedResource Remove="api\**" />
    </ItemGroup>
    <ItemGroup>
        <Content Remove="_site\**" />
        <Content Remove="api\**" />
    </ItemGroup>
    <ItemGroup>
        <None Remove="_site\**" />
        <None Remove="api\**" />
    </ItemGroup>
    <ItemGroup>
        <_ContentIncludedByDefault Remove="_site\api\toc.json" />
        <_ContentIncludedByDefault Remove="_site\docs\toc.json" />
        <_ContentIncludedByDefault Remove="_site\index.json" />
        <_ContentIncludedByDefault Remove="_site\manifest.json" />
        <_ContentIncludedByDefault Remove="_site\toc.json" />
    </ItemGroup>
    <ItemGroup>
        <Watch Include="_site/**/*.*" />
        <Watch Include="**/*.cs" />
    </ItemGroup>

    <!-- Hide everything from Compze junction except _docs folders -->
    <ItemGroup>
        <!-- Remove ALL items from Compze -->
        <Compile Remove="Compze\**" />
        <Content Remove="Compze\**" />
        <None Remove="Compze\**" />
        
        <!-- Include ONLY _docs content -->
        <Compile Include="Compze\**\_docs\*.cs" />
        <Content Include="Compze\**\_docs\*.md" />
        <Content Include="Compze\**\_docs\*.yml" />
        <None Include="Compze\**\_docs\**" Exclude="Compze\**\_docs\*.cs;Compze\**\_docs\*.md;Compze\**\_docs\*.yml" />
    </ItemGroup>
</Project>