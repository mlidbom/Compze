<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.1.0-alpha</Version>
    <!-- TODO: Remove once all public API members have XML documentation comments -->
    <NoWarn>CS1591</NoWarn>
    <Description>Database-local integer interning for stable type identity: maps a Compze TypeId to a small, per-database int and back for compact storage references, durably linking every spelling a type has been persisted as (reclassification and renames) behind a small, storage-agnostic provider interface. Depends only on Compze.TypeIdentifiers.</Description>
    <PackageTags>type-identity;type-mapping;interning;serialization;persistence</PackageTags>
  </PropertyGroup>
  <!-- Compze.TypeIdentifiers — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_TypeIdentifiers)' == 'true'">
    <PackageReference Include="Compze.TypeIdentifiers" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_TypeIdentifiers)' != 'true'">
    <ProjectReference Include="..\Compze.TypeIdentifiers\Compze.TypeIdentifiers.csproj" />
  </ItemGroup>
</Project>