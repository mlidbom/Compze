<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.1.0-alpha.1</Version>
    <Description>SQLite database pool support for Compze integration testing.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.1" />
  </ItemGroup>
  <!-- Compze.Sql.Sqlite — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Sql_Sqlite)' == 'true'">
    <PackageReference Include="Compze.Sql.Sqlite" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Sql_Sqlite)' != 'true'">
    <ProjectReference Include="..\Compze.Sql.Sqlite\Compze.Sql.Sqlite.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.Testing.DbPool — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_DbPool)' == 'true'">
    <PackageReference Include="Compze.Utilities.Testing.DbPool" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_DbPool)' != 'true'">
    <ProjectReference Include="..\Compze.Utilities.Testing.DbPool\Compze.Utilities.Testing.DbPool.csproj" />
  </ItemGroup>
</Project>