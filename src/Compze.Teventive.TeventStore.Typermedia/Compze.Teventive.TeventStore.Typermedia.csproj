<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.2.0-alpha</Version>
    <!-- TODO: Remove once all public API members have XML documentation comments -->
    <NoWarn>CS1591</NoWarn>
    <Description>Typermedia API bridge for the Compze event store — exposes event store operations as Typermedia tueries and tommands.</Description>
  </PropertyGroup>
  <!-- Compze.Abstractions — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Abstractions)' == 'true'">
    <PackageReference Include="Compze.Abstractions" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Abstractions)' != 'true'">
    <ProjectReference Include="..\Compze.Abstractions\Compze.Abstractions.csproj" />
  </ItemGroup>
  <!-- Compze.Core — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Core)' == 'true'">
    <PackageReference Include="Compze.Core" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Core)' != 'true'">
    <ProjectReference Include="..\Compze.Core\Compze.Core.csproj" />
  </ItemGroup>
  <!-- Compze.DependencyInjection — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_DependencyInjection)' == 'true'">
    <PackageReference Include="Compze.DependencyInjection" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_DependencyInjection)' != 'true'">
    <ProjectReference Include="..\Compze.DependencyInjection\Compze.DependencyInjection.csproj" />
  </ItemGroup>
  <!-- Compze.Tessaging.Abstractions — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Tessaging_Abstractions)' == 'true'">
    <PackageReference Include="Compze.Tessaging.Abstractions" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Tessaging_Abstractions)' != 'true'">
    <ProjectReference Include="..\Compze.Tessaging.Abstractions\Compze.Tessaging.Abstractions.csproj" />
  </ItemGroup>
  <!-- Compze.Teventive.TeventStore — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Teventive_TeventStore)' == 'true'">
    <PackageReference Include="Compze.Teventive.TeventStore" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Teventive_TeventStore)' != 'true'">
    <ProjectReference Include="..\Compze.Teventive.TeventStore\Compze.Teventive.TeventStore.csproj" />
  </ItemGroup>
  <!-- Compze.Typermedia — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Typermedia)' == 'true'">
    <PackageReference Include="Compze.Typermedia" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Typermedia)' != 'true'">
    <ProjectReference Include="..\Compze.Typermedia\Compze.Typermedia.csproj" />
  </ItemGroup>
  <!-- Compze.Typermedia.Client — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Typermedia_Client)' == 'true'">
    <PackageReference Include="Compze.Typermedia.Client" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Typermedia_Client)' != 'true'">
    <ProjectReference Include="..\Compze.Typermedia.Client\Compze.Typermedia.Client.csproj" />
  </ItemGroup>
</Project>