<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.1.0-alpha.1</Version>
    <Description>Microsoft SQL Server database pool support for Compze integration testing.</Description>
  </PropertyGroup>
  <!-- Compze.Sql.MicrosoftSql — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Sql_MicrosoftSql)' == 'true'">
    <PackageReference Include="Compze.Sql.MicrosoftSql" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Sql_MicrosoftSql)' != 'true'">
    <ProjectReference Include="..\Compze.Sql.MicrosoftSql\Compze.Sql.MicrosoftSql.csproj" />
  </ItemGroup>
  <!-- Compze.Utilities.Testing.DbPool — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_DbPool)' == 'true'">
    <PackageReference Include="Compze.Utilities.Testing.DbPool" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Utilities_Testing_DbPool)' != 'true'">
    <ProjectReference Include="..\Compze.Utilities.Testing.DbPool\Compze.Utilities.Testing.DbPool.csproj" />
  </ItemGroup>
</Project>