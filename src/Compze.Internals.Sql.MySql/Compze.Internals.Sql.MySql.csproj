<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.2.1-alpha</Version>
    <!-- TODO: Remove once all public API members have XML documentation comments -->
    <NoWarn>CS1591</NoWarn>
    <Description>For Compze internal use only. Do not take a direct dependency on this package. MySQL connection, pool, and command plumbing shared by the Compze.*.MySql feature backends.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MySql.Data" Version="9.4.0" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Compze.TypeIdentifiers.Interning.MySql" />
    <InternalsVisibleTo Include="Compze.DocumentDb.MySql" />
    <InternalsVisibleTo Include="Compze.ServiceBus.MySql" />
    <InternalsVisibleTo Include="Compze.Teventive.TeventStore.MySql" />
  </ItemGroup>
  <!-- Compze.Abstractions — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Abstractions)' == 'true'">
    <PackageReference Include="Compze.Abstractions" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Abstractions)' != 'true'">
    <ProjectReference Include="..\Compze.Abstractions\Compze.Abstractions.csproj" />
  </ItemGroup>
  <!-- Compze.Internals.Sql.Common — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Sql_Common)' == 'true'">
    <PackageReference Include="Compze.Internals.Sql.Common" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Sql_Common)' != 'true'">
    <ProjectReference Include="..\Compze.Internals.Sql.Common\Compze.Internals.Sql.Common.csproj" />
  </ItemGroup>
</Project>