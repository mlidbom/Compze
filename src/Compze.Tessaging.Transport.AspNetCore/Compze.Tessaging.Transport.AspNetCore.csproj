<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.3.0-alpha</Version>
    <!-- TODO:docs: Remove once all public API members have XML documentation comments -->
    <NoWarn>CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Seq.Extensions.Logging" Version="9.0.0" />
  </ItemGroup>
  <!-- Compze.Abstractions — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Abstractions)' == 'true'">
    <PackageReference Include="Compze.Abstractions" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Abstractions)' != 'true'">
    <ProjectReference Include="..\Compze.Abstractions\Compze.Abstractions.csproj" />
  </ItemGroup>
  <!-- Compze.Contracts — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Contracts)' == 'true'">
    <PackageReference Include="Compze.Contracts" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Contracts)' != 'true'">
    <ProjectReference Include="..\Compze.Contracts\Compze.Contracts.csproj" />
  </ItemGroup>
  <!-- Compze.DependencyInjection — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_DependencyInjection)' == 'true'">
    <PackageReference Include="Compze.DependencyInjection" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_DependencyInjection)' != 'true'">
    <ProjectReference Include="..\Compze.DependencyInjection\Compze.DependencyInjection.csproj" />
  </ItemGroup>
  <!-- Compze.DependencyInjection.Extensions.Hosting — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_DependencyInjection_Extensions_Hosting)' == 'true'">
    <PackageReference Include="Compze.DependencyInjection.Extensions.Hosting" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_DependencyInjection_Extensions_Hosting)' != 'true'">
    <ProjectReference Include="..\Compze.DependencyInjection.Extensions.Hosting\Compze.DependencyInjection.Extensions.Hosting.csproj" />
  </ItemGroup>
  <!-- Compze.Internals.Logging — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Logging)' == 'true'">
    <PackageReference Include="Compze.Internals.Logging" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Logging)' != 'true'">
    <ProjectReference Include="..\Compze.Internals.Logging\Compze.Internals.Logging.csproj" />
  </ItemGroup>
  <!-- Compze.Tessaging — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Tessaging)' == 'true'">
    <PackageReference Include="Compze.Tessaging" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Tessaging)' != 'true'">
    <ProjectReference Include="..\Compze.Tessaging\Compze.Tessaging.csproj" />
  </ItemGroup>
</Project>