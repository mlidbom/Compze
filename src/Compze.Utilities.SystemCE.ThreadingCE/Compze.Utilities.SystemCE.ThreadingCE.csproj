<Project Sdk="Microsoft.NET.Sdk">
   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
      <Nullable>enable</Nullable>
      <Version>0.1.0-alpha.3</Version>
   </PropertyGroup>
   <ItemGroup>
      <FlexiReference Include="Compze.Utilities.Contracts" ProjectPath="..\Compze.Utilities.Contracts\Compze.Utilities.Contracts.csproj" Version="$(CompzePackageVersion)" />
      <FlexiReference Include="Compze.Utilities.Functional" ProjectPath="..\Compze.Utilities.Functional\Compze.Utilities.Functional.csproj" Version="$(CompzePackageVersion)" />
   </ItemGroup>
   <PropertyGroup>
      <InternalizeSourceFrom>..\Compze.Utilities.SystemCE</InternalizeSourceFrom>
      <InternalizeSourceTo>$(MSBuildProjectDirectory)\InternalizedSource</InternalizeSourceTo>
   </PropertyGroup>
   <ItemGroup>
      <PackageReference Include="Compze.InternalizedSourceReferences" Version="0.1.0-alpha.2" PrivateAssets="all" />
      <PackageReference Include="JetBrains.Annotations" Version="2025.2.4" />
      <PackageReference Include="NsDepCop" Version="2.6.0">
         <PrivateAssets>all</PrivateAssets>
         <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
   </ItemGroup>
</Project>