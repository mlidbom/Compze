<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Version>0.3.0-alpha</Version>
    <!-- TODO:docs: Remove once all public API members have XML documentation comments -->
    <NoWarn>CS1591</NoWarn>
    <Description>For Compze internal use only. Do not take a direct dependency on this package. SQLite connection, pool, and command plumbing shared by the Compze.*.Sqlite feature backends.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.1" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Compze.TypeIdentifiers.Interning.Sqlite" />
    <InternalsVisibleTo Include="Compze.DocumentDb.Sqlite" />
    <InternalsVisibleTo Include="Compze.Tessaging.Sqlite" />
    <InternalsVisibleTo Include="Compze.Teventive.TeventStore.Sqlite" />
  </ItemGroup>
  <!-- Compze.Abstractions — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Abstractions)' == 'true'">
    <PackageReference Include="Compze.Abstractions" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Abstractions)' != 'true'">
    <ProjectReference Include="..\Compze.Abstractions\Compze.Abstractions.csproj" />
  </ItemGroup>
  <!-- Compze.Internals.Sql.Common — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Sql_Common)' == 'true'">
    <PackageReference Include="Compze.Internals.Sql.Common" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Internals_Sql_Common)' != 'true'">
    <ProjectReference Include="..\Compze.Internals.Sql.Common\Compze.Internals.Sql.Common.csproj" />
  </ItemGroup>
</Project>