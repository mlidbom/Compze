<Project Sdk="Microsoft.NET.Sdk">
   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
      <Nullable>enable</Nullable>
      <Version>0.1.0-alpha.4</Version>
      <Description>SimpleInjector dependency injection integration for the Compze framework.</Description>
   </PropertyGroup>
   <ItemGroup>
      <PackageReference Include="SimpleInjector" Version="5.5.0" />
      <PackageReference Include="NsDepCop" Version="2.6.0">
         <PrivateAssets>all</PrivateAssets>
         <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
   </ItemGroup>
   <ItemGroup>
      <FlexiReference Include="Compze.Utilities.Contracts" ProjectPath="..\Compze.Utilities.Contracts\Compze.Utilities.Contracts.csproj" Version="$(CompzePackageVersion)" />
      <FlexiReference Include="Compze.Utilities.Functional" ProjectPath="..\Compze.Utilities.Functional\Compze.Utilities.Functional.csproj" Version="$(CompzePackageVersion)" />
      <FlexiReference Include="Compze.Utilities.DependencyInjection" ProjectPath="..\Compze.Utilities.DependencyInjection\Compze.Utilities.DependencyInjection.csproj" Version="$(CompzePackageVersion)" />
      <FlexiReference Include="Compze.Utilities.Logging" ProjectPath="..\Compze.Utilities.Logging\Compze.Utilities.Logging.csproj" Version="$(CompzePackageVersion)" />
      <FlexiReference Include="Compze.Utilities.SystemCE" ProjectPath="..\Compze.Utilities.SystemCE\Compze.Utilities.SystemCE.csproj" Version="$(CompzePackageVersion)" />
      <FlexiReference Include="Compze.Utilities.SystemCE.ThreadingCE" ProjectPath="..\Compze.Utilities.SystemCE.ThreadingCE\Compze.Utilities.SystemCE.ThreadingCE.csproj" Version="$(CompzePackageVersion)" />
   </ItemGroup>
</Project>