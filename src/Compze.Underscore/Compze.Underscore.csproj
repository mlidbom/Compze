<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <Version>0.6.0</Version>
    <Description>Code that reads the way you would describe the algorithm in words. Powered by the pipe forward operator and friends.</Description>
    <PackageTags>compze;functional;pipe;unit;extensions;csharp</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="NsDepCop" Version="2.6.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <!-- Compze.Unit — flex reference -->
  <ItemGroup Condition="'$(UsePackageReference_Compze_Unit)' == 'true'">
    <PackageReference Include="Compze.Unit" Version="*-*" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePackageReference_Compze_Unit)' != 'true'">
    <ProjectReference Include="..\Compze.Unit\Compze.Unit.csproj" />
  </ItemGroup>
</Project>