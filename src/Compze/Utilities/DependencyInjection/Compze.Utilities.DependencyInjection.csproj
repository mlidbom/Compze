<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <PropertyGroup>
    <NuGetAuditMode>direct</NuGetAuditMode>
    <AnalysisLevel>latest-all</AnalysisLevel>
    <RunAnalyzersDuringLiveAnalysis>False</RunAnalyzersDuringLiveAnalysis>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.9" />
    <PackageReference Include="JetBrains.Annotations" Version="2025.2.2">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\SystemExtensions\Compze.Utilities.SystemExtensions.csproj" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Compze.Utilities.DependencyInjection.Microsoft" />
    <InternalsVisibleTo Include="Compze.Utilities.DependencyInjection.SimpleInjector" />
    <InternalsVisibleTo Include="Compze.Tessaging.Persistence.InMemory" />
    <InternalsVisibleTo Include="Compze.Tessaging.Hosting.Persistence.MicrosoftSql" />
    <InternalsVisibleTo Include="Compze.Tessaging.Hosting.Persistence.MySql" />
    <InternalsVisibleTo Include="Compze.Tessaging.Hosting.Persistence.PostgreSql" />
    <InternalsVisibleTo Include="Compze.Tessaging" />
    <InternalsVisibleTo Include="Compze.Tessaging.Hosting.Testing" />
    <InternalsVisibleTo Include="Compze.Tests.Integration" />
  </ItemGroup>
  <!-- Exclude subdirectories that have their own .csproj files to hide them from Solution Explorer.
       This section is automatically maintained by DevScripts\Fix-CsprojExclusions.ps1 -->
  <ItemGroup>
    <Compile Remove="Abstractions\**" />
    <EmbeddedResource Remove="Abstractions\**" />
    <None Remove="Abstractions\**" />
    <Content Remove="Abstractions\**" />
    <Compile Remove="Microsoft\**" />
    <EmbeddedResource Remove="Microsoft\**" />
    <None Remove="Microsoft\**" />
    <Content Remove="Microsoft\**" />
    <Compile Remove="SimpleInjector\**" />
    <EmbeddedResource Remove="SimpleInjector\**" />
    <None Remove="SimpleInjector\**" />
    <Content Remove="SimpleInjector\**" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Abstractions\_DependencyInjectionApi.cs" />
  </ItemGroup>
</Project>