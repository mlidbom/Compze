<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<Nullable>enable</Nullable>
		<Version>0.1.0-alpha.1</Version>
		<Description>Core utilities for the Compze framework including dependency injection abstractions, system extensions, and threading helpers.</Description>
	</PropertyGroup>
	<ItemGroup>
      <PackageReference Include="JetBrains.Annotations" Version="2025.2.2" />
      <PackageReference Include="NsDepCop" Version="2.6.0">
         <PrivateAssets>all</PrivateAssets>
         <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
	</ItemGroup>
  <ItemGroup>
    <Folder Include="SystemCE\TextCE\" />
    <Folder Include="SystemCE\ThreadingCE\Async\" />
  </ItemGroup>
  <!-- Exclude subdirectories that have their own .csproj files to prevent compilation errors.
       This section is automatically maintained by DevScripts\C-Ensure-CsprojfilesExcludeCsFilesFromProjectsInSubfoldersAndDocsFolders.ps1 -->
