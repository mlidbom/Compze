    <None Remove="DependencyInjection\SimpleInjector\**" />
    <Content Remove="DependencyInjection\SimpleInjector\**" />
    <Compile Remove="Logging\Serilog\**" />
    <EmbeddedResource Remove="Logging\Serilog\**" />
    <None Remove="Logging\Serilog\**" />
    <Content Remove="Logging\Serilog\**" />
    <Compile Remove="Testing\DbPool\**" />
    <EmbeddedResource Remove="Testing\DbPool\**" />
    <None Remove="Testing\DbPool\**" />
    <Content Remove="Testing\DbPool\**" />
    <Compile Remove="Testing\Must\**" />
