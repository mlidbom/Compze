<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <PropertyGroup>
    <RootNamespace>Compze.Logging</RootNamespace>
    <NuGetAuditMode>direct</NuGetAuditMode>
    <AnalysisLevel>latest-all</AnalysisLevel>
    <RunAnalyzersDuringLiveAnalysis>False</RunAnalyzersDuringLiveAnalysis>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Serialization\Compze.Serialization.csproj" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Compze.Tessaging.Teventive.EventStore" />
    <InternalsVisibleTo Include="Compze.Utilities.Logging.Serilog" />
    <InternalsVisibleTo Include="Compze.Persistence.Common" />
    <InternalsVisibleTo Include="Compze.Tessaging" />
    <InternalsVisibleTo Include="Compze.Tessaging.Hosting.Testing" />
    <InternalsVisibleTo Include="Compze.Utilities.Testing.DbPool" />
    <InternalsVisibleTo Include="Compze.TestInfrastructure" />
    <InternalsVisibleTo Include="Compze.Tests.Performance.Internals" />
    <InternalsVisibleTo Include="Compze.Tests.Unit.Internals" />
  </ItemGroup>
  <!-- Exclude subdirectories that have their own .csproj files to hide them from Solution Explorer.
       This section is automatically maintained by DevScripts\Fix-CsprojExclusions.ps1 -->
  <ItemGroup>
    <Compile Remove="Abstractions\**" />
    <EmbeddedResource Remove="Abstractions\**" />
    <None Remove="Abstractions\**" />
    <Content Remove="Abstractions\**" />
    <Compile Remove="Serilog\**" />
    <EmbeddedResource Remove="Serilog\**" />
    <None Remove="Serilog\**" />
    <Content Remove="Serilog\**" />
  </ItemGroup>
</Project>