<Project Sdk="Microsoft.NET.Sdk">
   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
	   <RootNamespace>Compze.Tessaging</RootNamespace>
      <Nullable>enable</Nullable>
      <!--todo: get this into all our csproj files when we start publishing, to guarantee semantic versioning <PackageValidationBaselineVersion>1.0.0.0</PackageValidationBaselineVersion>-->
   </PropertyGroup>
   <ItemGroup>
      <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
   </ItemGroup>
   <ItemGroup>
      <ProjectReference Include="..\..\Abstractions\Compze.Abstractions.csproj" />
      <ProjectReference Include="..\..\Abstractions\Internal\Compze.Abstractions.Internal.csproj" />
      <ProjectReference Include="..\..\Utilities\Compze.Utilities.csproj" />
   </ItemGroup>
  <!-- Exclude _docs files from compilation but keep them visible.
       This section is automatically maintained by DevScripts\C-Ensure-CsprojfilesExcludeCsFilesFromProjectsInSubfoldersAndDocsFolders.ps1 -->
  <ItemGroup>
    <Compile Remove="_Docs\**\*.cs" />
    <None Include="_Docs\**\*.cs" />
    <Content Include="_Docs\**\*.md" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Hosting\Abstractions\" />
  </ItemGroup>
</Project>