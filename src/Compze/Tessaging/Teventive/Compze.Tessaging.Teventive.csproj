    <None Remove="EventStore\**" />
    <Content Remove="EventStore\**" />
    <Compile Remove="EventStore\Abstractions\**" />
    <EmbeddedResource Remove="EventStore\Abstractions\**" />
    <None Remove="EventStore\Abstractions\**" />
    <Content Remove="EventStore\Abstractions\**" />
    <Compile Remove="EventStore\MicrosoftSql\**" />
    <EmbeddedResource Remove="EventStore\MicrosoftSql\**" />
    <None Remove="EventStore\MicrosoftSql\**" />
    <Content Remove="EventStore\MicrosoftSql\**" />
    <Compile Remove="EventStore\MySql\**" />
    <EmbeddedResource Remove="EventStore\MySql\**" />
    <None Remove="EventStore\MySql\**" />
    <Content Remove="EventStore\MySql\**" />
    <Compile Remove="EventStore\PostgreSql\**" />
    <EmbeddedResource Remove="EventStore\PostgreSql\**" />
    <None Remove="EventStore\PostgreSql\**" />
    <Content Remove="EventStore\PostgreSql\**" />
  </ItemGroup>
</Project>