<Project Sdk="Microsoft.NET.Sdk">
   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
      <Nullable>enable</Nullable>
   </PropertyGroup>
   <ItemGroup>
      <PackageReference Include="JetBrains.Annotations" Version="2025.2.2">
         <PrivateAssets>all</PrivateAssets>
      </PackageReference>
   </ItemGroup>
   <ItemGroup>
      <ProjectReference Include="..\..\Abstractions\Compze.Abstractions.csproj" />
   </ItemGroup>
  <!-- Exclude _docs files from compilation but keep them visible.
       This section is automatically maintained by DevScripts\C-Ensure-CsprojfilesExcludeCsFilesFromProjectsInSubfoldersAndDocsFolders.ps1 -->
  <ItemGroup>
    <Compile Remove="_docs\**\*.cs" />
    <None Include="_docs\**\*.cs" />
    <Content Include="_docs\**\*.md" />
  </ItemGroup>
  <!-- Exclude subdirectories that have their own .csproj files to prevent compilation errors.
       This section is automatically maintained by DevScripts\C-Ensure-CsprojfilesExcludeCsFilesFromProjectsInSubfoldersAndDocsFolders.ps1 -->
  <ItemGroup>
    <Compile Remove="TeventStore\**" />
    <EmbeddedResource Remove="TeventStore\**" />
    <None Remove="TeventStore\**" />
    <Content Remove="TeventStore\**" />
  </ItemGroup>
</Project>