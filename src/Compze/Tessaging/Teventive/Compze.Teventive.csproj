<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <PropertyGroup>
    <RootNamespace>Compze.Teventive</RootNamespace>
    <NuGetAuditMode>direct</NuGetAuditMode>
    <AnalysisLevel>latest-all</AnalysisLevel>
    <RunAnalyzersDuringLiveAnalysis>False</RunAnalyzersDuringLiveAnalysis>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="Abstractions\**" />
    <Compile Remove="EventStore\**" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="JetBrains.Annotations" Version="2025.2.2">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\Abstractions\Internal\Compze.Abstractions.Internal.csproj" />
    <ProjectReference Include="..\Common\Compze.Tessaging.Common.csproj" />
    <ProjectReference Include="Abstractions\Compze.Teventive.Abstractions.csproj" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Compze.EventStore" />
  </ItemGroup>
</Project>