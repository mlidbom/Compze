<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <PropertyGroup>
        <RootNamespace>Compze.Testing.DbPool</RootNamespace>
        <NuGetAuditMode>direct</NuGetAuditMode>
        <AnalysisLevel>latest-all</AnalysisLevel>
        <RunAnalyzersDuringLiveAnalysis>False</RunAnalyzersDuringLiveAnalysis>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\Compze.Configuration\Compze.Tessaging.Hosting.Configuration.csproj" />
        <ProjectReference Include="..\Compze.Logging\Compze.Utilities.Logging.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="JetBrains.Annotations" Version="2025.2.2" />
        <PackageReference Include="System.Threading.AccessControl" Version="9.0.9" />
    </ItemGroup>
    
    <ItemGroup>
      <InternalsVisibleTo Include="Compze.Testing.DbPool.MicrosoftSql" />
      <InternalsVisibleTo Include="Compze.Testing.DbPool.PostgreSql" />
      <InternalsVisibleTo Include="Compze.Testing.DbPool.MySql" />
      <InternalsVisibleTo Include="Compze.Tests.Performance.Internals" />
      <InternalsVisibleTo Include="Compze.Tests.Unit.Internals" />
    </ItemGroup>

</Project>
