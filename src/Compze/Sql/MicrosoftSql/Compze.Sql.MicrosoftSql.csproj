<Project Sdk="Microsoft.NET.Sdk">
   <PropertyGroup>
      <TargetFramework>net9.0</TargetFramework>
      <Nullable>enable</Nullable>
      <Version>0.1.0-alpha.2</Version>
      <Description>Microsoft SQL Server support for the Compze framework.</Description>
   </PropertyGroup>
   <ItemGroup>
      <ProjectReference Include="..\..\Abstractions\Compze.Core.csproj" />
      <ProjectReference Include="..\Common\Compze.Sql.Common.csproj" />
   </ItemGroup>
   <ItemGroup>
      <PackageReference Include="Microsoft.Data.SqlClient" Version="6.1.2" />
      <PackageReference Include="NsDepCop" Version="2.6.0">
         <PrivateAssets>all</PrivateAssets>
         <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      </PackageReference>
   </ItemGroup>
</Project>