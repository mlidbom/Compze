      <InternalsVisibleTo Include="Compze.EventStore" />
      <InternalsVisibleTo Include="Compze.EventStore.MicrosoftSql" />
      <InternalsVisibleTo Include="Compze.EventStore.MySql" />
      <InternalsVisibleTo Include="Compze.EventStore.PostgreSql" />
      <InternalsVisibleTo Include="Compze.Persistence.MicrosoftSql.DependencyInjection" />
      <InternalsVisibleTo Include="Compze.Persistence.MicrosoftSql.Infrastructure" />
      <InternalsVisibleTo Include="Compze.Persistence.MySql.DependencyInjection" />
