<Project>
  <UsingTask TaskName="CircularLibraryDependencySourceRewriter.RewriteDirectoryTask"
             AssemblyFile="$(MSBuildThisFileDirectory)bin\$(Configuration)\net9.0\CircularLibraryDependencySourceRewriter.dll" />

  <!-- Exclude internalized source from the SDK's default glob to avoid double-inclusion -->
  <ItemGroup Condition="'$(InternalizeSourceTo)' != ''">
    <Compile Remove="$(InternalizeSourceTo)\**" />
  </ItemGroup>

  <Target Name="RewriteInternalizedSource"
          BeforeTargets="CoreCompile"
          Condition="'$(InternalizeSourceFrom)' != '' AND '$(InternalizeSourceTo)' != ''">

    <RewriteDirectoryTask InputDirectories="$(InternalizeSourceFrom)"
                          OutputDirectory="$(InternalizeSourceTo)" />

    <!-- Include the generated files in compilation -->
    <ItemGroup>
      <Compile Include="$(InternalizeSourceTo)\**\*.cs" />
    </ItemGroup>
  </Target>
</Project>
